// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output = "./src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Listing {
  id            String   @id @default(uuid())
  title         String
  description   String
  category      String   // toys | cradles | shoes | clothes | books
  condition     String   // good | like-new | fair
  photos        String   @default("[]") // JSON array of photo paths
  area          String   // area in Trivandrum e.g. Pattom, Kowdiar
  donorName     String
  donorPhone    String
  donorWhatsapp String?
  status        String   @default("available") // available | claimed
  feePaid       Boolean  @default(false)
  feeAmount     Int      @default(10) // Rs 10-30
  paymentId     String?
  ageGroup      String?  // 0-1 | 1-3 | 3-6 | 6-12 | any
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([createdAt])
}
